#!/usr/bin/env python3

import argparse
import json
import select
from pathlib import Path
import sys
import termios
import threading
import time
import tty

import cv2
import numpy as np

import crtk
import dvrk


KEY_UP = "UP"
KEY_DOWN = "DOWN"
KEY_LEFT = "LEFT"
KEY_RIGHT = "RIGHT"
KEY_PLUS = "+"
KEY_MINUS = "-"
KEY_QUIT = "q"
KEY_FULLSCREEN = "f"
KEY_RESET_SHIFT = "r"
KEY_COLOR_CALIBRATE = "c"
KEY_LINE_LEFT = "["
KEY_LINE_RIGHT = "]"
KEY_LINE_TOGGLE = "g"
KEY_PSM_OSCILLATE = "v"
KEY_STRETCH_OUT = "o"
KEY_STRETCH_IN = "p"


class TerminalInput:
    def __init__(self):
        self.old_settings = termios.tcgetattr(sys.stdin)

    def __enter__(self):
        tty.setcbreak(sys.stdin.fileno())
        return self

    def __exit__(self, exc_type, exc_value, traceback):
        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, self.old_settings)

    def get_key(self):
        # Read the most recent key only to prevent buffering lag
        key = None
        while select.select([sys.stdin], [], [], 0)[0]:
            ch = sys.stdin.read(1)
            if ch == "\x1b":
                ch2 = sys.stdin.read(1)
                if ch2 == "[":
                    ch3 = sys.stdin.read(1)
                    if ch3 == "A":
                        key = KEY_UP
                    elif ch3 == "B":
                        key = KEY_DOWN
                    elif ch3 == "C":
                        key = KEY_RIGHT
                    elif ch3 == "D":
                        key = KEY_LEFT
                continue
            if ch in ("q", "Q"):
                key = KEY_QUIT
            elif ch in ("f", "F"):
                key = KEY_FULLSCREEN
            elif ch in ("+", "="):
                key = KEY_PLUS
            elif ch in ("-", "_"):
                key = KEY_MINUS
            elif ch in ("r", "R"):
                key = KEY_RESET_SHIFT
            elif ch in ("c", "C"):
                key = KEY_COLOR_CALIBRATE
            elif ch == "[":
                key = KEY_LINE_LEFT
            elif ch == "]":
                key = KEY_LINE_RIGHT
            elif ch in ("g", "G"):
                key = KEY_LINE_TOGGLE
            elif ch in ("v", "V"):
                key = KEY_PSM_OSCILLATE
            elif ch in ("o", "O"):
                key = KEY_STRETCH_OUT
            elif ch in ("p", "P"):
                key = KEY_STRETCH_IN
        return key


def clip_int(value: int, min_value: int, max_value: int) -> int:
    return max(min_value, min(max_value, value))

def clip_float(value: float, min_value: float, max_value: float) -> float:
    return max(min_value, min(max_value, value))

def compute_stats(bgr):
    hsv = cv2.cvtColor(bgr, cv2.COLOR_BGR2HSV).astype(np.float32)
    mean_v, std_v = cv2.meanStdDev(hsv[:, :, 2])
    mean_s, std_s = cv2.meanStdDev(hsv[:, :, 1])
    return {
        "mean_v": float(mean_v[0][0]),
        "std_v": float(std_v[0][0]),
        "mean_s": float(mean_s[0][0]),
        "std_s": float(std_s[0][0])
    }

def calculate_match_from_stats(source_stats, target_stats):
    std_v_s = max(1.0, float(source_stats["std_v"]))
    contrast = float(target_stats["std_v"]) / std_v_s
    contrast = clip_float(float(contrast), 0.1, 2.0)
    
    brightness = (float(target_stats["mean_v"]) - float(source_stats["mean_v"]) * contrast) / 255.0
    brightness = clip_float(float(brightness), -1.0, 1.0)
    
    mean_s_s = max(1.0, float(source_stats["mean_s"]))
    saturation = float(target_stats["mean_s"]) / mean_s_s
    saturation = clip_float(float(saturation), 0.0, 2.0)
    
    return {"brightness": brightness, "contrast": contrast, "saturation": saturation, "hue": 0.0}

def calculate_calibration(mode, left_bgr, right_bgr):
    neutral = {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0}
    if mode == "none":
        return neutral, neutral
        
    left_stats = compute_stats(left_bgr)
    right_stats = compute_stats(right_bgr)
    
    if mode == "left_ref":
        return neutral, calculate_match_from_stats(right_stats, left_stats)
    elif mode == "right_ref":
        return calculate_match_from_stats(left_stats, right_stats), neutral
    elif mode == "average":
        avg_stats = {
            "mean_v": (left_stats["mean_v"] + right_stats["mean_v"]) / 2.0,
            "std_v": (left_stats["std_v"] + right_stats["std_v"]) / 2.0,
            "mean_s": (left_stats["mean_s"] + right_stats["mean_s"]) / 2.0,
            "std_s": (left_stats["std_s"] + right_stats["std_s"]) / 2.0
        }
        return calculate_match_from_stats(left_stats, avg_stats), calculate_match_from_stats(right_stats, avg_stats)
    return neutral, neutral

def apply_color_calibration_preview(bgr, color_params):
    brightness = color_params.get("brightness", 0.0)
    contrast = color_params.get("contrast", 1.0)
    saturation = color_params.get("saturation", 1.0)
    if brightness == 0.0 and contrast == 1.0 and saturation == 1.0:
        return bgr
        
    hsv = cv2.cvtColor(bgr, cv2.COLOR_BGR2HSV).astype(np.float32)
    hsv[:, :, 1] = np.clip(hsv[:, :, 1] * saturation, 0, 255)
    hsv[:, :, 2] = np.clip((hsv[:, :, 2] - 16) * contrast + 16 + brightness * 255.0, 0, 255)
    return cv2.cvtColor(hsv.astype(np.uint8), cv2.COLOR_HSV2BGR)


def compute_crop_size_from_percent(working_w: int, working_h: int, resize_percent: int):
    crop_w = max(1, int(round(working_w * 100.0 / resize_percent)))
    crop_h = max(1, int(round(working_h * 100.0 / resize_percent)))
    return crop_w, crop_h


def compute_resize_percent_from_crop(working_w: int, crop_w: int):
    if crop_w <= 0:
        return 100
    return clip_int(int(round(working_w * 100.0 / crop_w)), 100, 200)


def offset_valid_range(working_size: int, crop_size: int):
    crop_total = max(0, working_size - crop_size)
    center = crop_total // 2

    min_half = -center
    max_half = crop_total - center

    min_offset = int(np.ceil(2.0 * min_half)) + 1
    max_offset = int(np.floor(2.0 * max_half)) - 1

    if min_offset > max_offset:
        return 0, 0
    return min_offset, max_offset


def clamp_offset_to_valid(working_size: int, crop_size: int, offset_px: int) -> int:
    minimum, maximum = offset_valid_range(working_size, crop_size)
    return clip_int(offset_px, minimum, maximum)


def compute_axis_starts(crop_total: int, offset_px: int):
    center = crop_total // 2
    negative_start = center - int(np.floor(offset_px / 2.0))
    positive_start = center + int(np.ceil(offset_px / 2.0))
    return negative_start, positive_start


def compute_eye_crop(working_w: int, working_h: int, crop_w: int, crop_h: int, horizontal_shift: int, vertical_shift: int, sign: int):
    crop_x_total = max(0, working_w - crop_w)
    crop_y_total = max(0, working_h - crop_h)

    left_start, right_start = compute_axis_starts(crop_x_total, horizontal_shift)
    top_start, bottom_start = compute_axis_starts(crop_y_total, vertical_shift)

    left_crop = left_start if sign < 0 else right_start
    right_crop = crop_x_total - left_crop
    top_crop = top_start if sign < 0 else bottom_start
    bottom_crop = crop_y_total - top_crop
    return left_crop, right_crop, top_crop, bottom_crop


def crop_frame(frame, crop):
    left_crop, right_crop, top_crop, bottom_crop = crop
    height, width = frame.shape[:2]
    return frame[top_crop:height - bottom_crop, left_crop:width - right_crop]


def as_preview_pipeline(source_snippet: str) -> str:
    snippet = source_snippet.strip()
    if "appsink" in snippet:
        return snippet
    return f"{snippet} ! videoconvert ! appsink drop=true sync=false"


def open_capture(source_label: str, source_snippet: str):
    pipeline = as_preview_pipeline(source_snippet)
    cap = cv2.VideoCapture(pipeline, cv2.CAP_GSTREAMER)
    if not cap.isOpened():
        raise RuntimeError(
            f"Unable to open {source_label} source with GStreamer backend. "
            "Source must be a valid GStreamer snippet."
        )
    return cap


def ensure_config_fields(config):
    config.setdefault("type", "dd::display_config@1.0.0")
    config.setdefault("name", "dvrk_display")
    config.setdefault("dvrk_console_namespace", "console")
    config.setdefault("original_width", 0)
    config.setdefault("original_height", 0)
    config.setdefault("crop_width", 0)
    config.setdefault("crop_height", 0)
    config.setdefault("horizontal_shift_px", 0)
    config.setdefault("vertical_shift_px", 0)
    config.setdefault("display_horizontal_offset_px", 0)
    config.setdefault("left_stream", "")
    config.setdefault("right_stream", "")
    config.setdefault("sinks", ["glimage"])
    config.setdefault("left_color", {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0})
    config.setdefault("right_color", {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0})
    config.setdefault("preserve_size", True)
    return config


def load_or_create(path: Path):
    if path.exists():
        with path.open("r", encoding="utf-8") as stream:
            return json.load(stream)

    return {
        "type": "dd::display_config@1.0.0",
        "name": "dvrk_display",
        "dvrk_console_namespace": "console",
        "original_width": 0,
        "original_height": 0,
        "crop_width": 0,
        "crop_height": 0,
        "horizontal_shift_px": 0,
        "vertical_shift_px": 0,
        "display_horizontal_offset_px": 0,
        "left_stream": "",
        "right_stream": "",
        "sinks": ["glimage"],
        "preserve_size": True,
        "left_color": {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0},
        "right_color": {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0},
    }


def parse_args():
    parser = argparse.ArgumentParser(
        description=(
            "Interactive dvrk_display calibration tool. "
            "Loads or creates a JSON file, previews stereo composition, and saves crop/shift values in pixels."
        )
    )
    parser.add_argument("-c", "--config", required=True, help="Path to dvrk_display JSON config")
    parser.add_argument("-l", "--left", help="Left source GStreamer snippet")
    parser.add_argument("-r", "--right", help="Right source GStreamer snippet")
    parser.add_argument("-s", "--split", action="store_true", help="Split stereo view in two windows")
    parser.add_argument("-p", "--psm", help="PSM name to oscillate, e.g. PSM1")
    return parser.parse_args()


def apply_stream_overrides(config, args):
    if args.left is not None:
        config["left_stream"] = args.left
    if args.right is not None:
        config["right_stream"] = args.right


def update_config_from_runtime(config, left_stream, right_stream, original_w, original_h, crop_w, crop_h, horizontal_shift, vertical_shift, display_horizontal_offset, left_color, right_color):
    config["type"] = "dd::display_config@1.0.0"
    config.setdefault("name", "dvrk_display")

    config["left_stream"] = left_stream
    config["right_stream"] = right_stream
    config["original_width"] = int(original_w)
    config["original_height"] = int(original_h)
    config["crop_width"] = int(crop_w)
    config["crop_height"] = int(crop_h)
    config["horizontal_shift_px"] = int(horizontal_shift)
    config["vertical_shift_px"] = int(vertical_shift)
    config["display_horizontal_offset_px"] = int(display_horizontal_offset)
    config["left_color"] = left_color
    config["right_color"] = right_color


def interactive_tune(config, split_mode=False, psm_name=None):
    left_stream = config.get("left_stream", "").strip()
    right_stream = config.get("right_stream", "").strip()
    if not left_stream or not right_stream:
        raise RuntimeError("Both left_stream and right_stream are required")

    ral = None
    arm = None
    oscillating = False
    oscillation_start_time = 0.0
    oscillation_amplitude = np.pi / 4.0 # 45 degrees, total 90 (quarter turn)
    oscillation_frequency = 0.5 # 0.5 Hz
    initial_jp = None

    oscillation_lock = threading.Lock()
    def oscillation_thread():
        nonlocal oscillating, oscillation_start_time, initial_jp
        rate = ral.create_rate(500) # 500 Hz
        while rclpy.ok():
            with oscillation_lock:
                is_oscillating = oscillating
                start_time = oscillation_start_time
                base_jp = initial_jp

            if is_oscillating and arm:
                elapsed = time.time() - start_time
                offset = oscillation_amplitude * np.sin(2 * np.pi * oscillation_frequency * elapsed)
                target_jp = np.copy(base_jp)
                target_jp[3] = base_jp[3] + offset
                arm.servo_jp(target_jp)
            rate.sleep()

    if psm_name:
        import rclpy
        ral = crtk.ral("dvrk_calibration_gui")
        arm = dvrk.psm(ral, psm_name)
        # Spin in background thread for CRTK
        ral.spin()
        # Give some time for publishers/subscribers to connect
        time.sleep(0.5)

        # Start background thread for high-frequency oscillation
        t_osc = threading.Thread(target=oscillation_thread, daemon=True)
        t_osc.start()

    left_cap = open_capture("left", left_stream)
    right_cap = open_capture("right", right_stream)

    ok_left, left_frame = left_cap.read()
    ok_right, right_frame = right_cap.read()
    if not ok_left or left_frame is None or not ok_right or right_frame is None:
        raise RuntimeError("Unable to read first frame from one or both sources")

    left_h, left_w = left_frame.shape[:2]
    right_h, right_w = right_frame.shape[:2]

    detected_w = min(left_w, right_w)
    detected_h = min(left_h, right_h)
    original_w = int(config.get("original_width", 0)) or detected_w
    original_h = int(config.get("original_height", 0)) or detected_h

    original_w = min(original_w, detected_w)
    original_h = min(original_h, detected_h)

    configured_crop_w = int(config.get("crop_width", 0))
    configured_crop_h = int(config.get("crop_height", 0))
    if configured_crop_w > 0:
        resize_percent = compute_resize_percent_from_crop(original_w, configured_crop_w)
    elif configured_crop_h > 0:
        resize_percent = compute_resize_percent_from_crop(original_h, configured_crop_h)
    else:
        resize_percent = 100
    crop_w, crop_h = compute_crop_size_from_percent(original_w, original_h, resize_percent)
    width_offset = 0
    if configured_crop_w > 0:
        width_offset = configured_crop_w - crop_w

    horizontal_shift = int(config.get("horizontal_shift_px", 0))
    vertical_shift = int(config.get("vertical_shift_px", 0))
    display_horizontal_offset = int(config.get("display_horizontal_offset_px", 0))
    show_grid = False
    horizontal_shift = clamp_offset_to_valid(original_w, crop_w, horizontal_shift)
    vertical_shift = clamp_offset_to_valid(original_h, crop_h, vertical_shift)
    
    color_calibration_modes = ["none", "left_ref", "right_ref", "average"]
    current_color_mode_idx = 0
    left_color_calibration = config.get("left_color", {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0})
    right_color_calibration = config.get("right_color", {"brightness": 0.0, "contrast": 1.0, "saturation": 1.0, "hue": 0.0})
    
    right_active = right_color_calibration.get("brightness", 0.0) != 0.0 or right_color_calibration.get("contrast", 1.0) != 1.0 or right_color_calibration.get("saturation", 1.0) != 1.0
    left_active = left_color_calibration.get("brightness", 0.0) != 0.0 or left_color_calibration.get("contrast", 1.0) != 1.0 or left_color_calibration.get("saturation", 1.0) != 1.0
    
    if right_active and left_active:
        current_color_mode_idx = 3 # average
    elif right_active:
        current_color_mode_idx = 1 # left_ref
    elif left_active:
        current_color_mode_idx = 2 # right_ref

    window_name = "stereo_preview"
    left_window_name = "left_preview"
    right_window_name = "right_preview"
    overlay_name = "stereo_overlay"
    preview_fullscreen = False

    if split_mode:
        cv2.namedWindow(left_window_name, cv2.WINDOW_NORMAL | cv2.WINDOW_KEEPRATIO | cv2.WINDOW_GUI_NORMAL)
        cv2.resizeWindow(left_window_name, max(640, crop_w), max(360, crop_h))
        cv2.namedWindow(right_window_name, cv2.WINDOW_NORMAL | cv2.WINDOW_KEEPRATIO | cv2.WINDOW_GUI_NORMAL)
        cv2.resizeWindow(right_window_name, max(640, crop_w), max(360, crop_h))
    else:
        cv2.namedWindow(window_name, cv2.WINDOW_NORMAL | cv2.WINDOW_KEEPRATIO | cv2.WINDOW_GUI_NORMAL)
        cv2.resizeWindow(window_name, max(960, 2 * crop_w), max(360, crop_h))

    cv2.namedWindow(overlay_name, cv2.WINDOW_NORMAL | cv2.WINDOW_KEEPRATIO | cv2.WINDOW_GUI_NORMAL)
    cv2.resizeWindow(overlay_name, max(640, crop_w), max(360, crop_h))

    print(
        "Detected sizes: "
        f"left={left_w}x{left_h}, right={right_w}x{right_h}, "
        f"original={original_w}x{original_h}"
    )
    print("Controls: +/- resize (1%), o/p stretch, arrows=shift, []:display_offset, r=reset shift, c=color calib, g=toggle grid, f=fullscreen, q=quit, v=PSM oscillation")

    # Initialize grid for calibration
    grid_rows = 3
    grid_cols = 4
    grid_colors = [tuple(np.random.randint(0, 256, 3).tolist()) for _ in range(grid_rows * grid_cols)]

    with TerminalInput() as term:
        while True:
            # OpenCV Loop (Display and Key Handling)
            ok_left, left_frame = left_cap.read()
            ok_right, right_frame = right_cap.read()
            if not ok_left or left_frame is None:
                left_cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
                ok_left, left_frame = left_cap.read()
            if not ok_right or right_frame is None:
                right_cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
                ok_right, right_frame = right_cap.read()
            if not ok_left or not ok_right or left_frame is None or right_frame is None:
                continue

            left_base = left_frame[:original_h, :original_w]
            right_base = right_frame[:original_h, :original_w]

            crop_w, crop_h = compute_crop_size_from_percent(original_w, original_h, resize_percent)
            crop_w = clip_int(crop_w + width_offset, 1, original_w)

            horizontal_shift = clamp_offset_to_valid(original_w, crop_w, horizontal_shift)
            vertical_shift = clamp_offset_to_valid(original_h, crop_h, vertical_shift)

            left_crop = compute_eye_crop(original_w, original_h, crop_w, crop_h, horizontal_shift, vertical_shift, sign=-1)
            right_crop = compute_eye_crop(original_w, original_h, crop_w, crop_h, horizontal_shift, vertical_shift, sign=1)

            left_out = crop_frame(left_base, left_crop)
            right_out = crop_frame(right_base, right_crop)

            if left_out.size == 0 or right_out.size == 0:
                continue

            left_preview = apply_color_calibration_preview(left_out, left_color_calibration)
            right_preview = apply_color_calibration_preview(right_out, right_color_calibration)

            if show_grid:
                curr_h, curr_w = left_preview.shape[:2]
                center_x = curr_w // 2

                # Square size: 5% of height (using height to keep them square-ish)
                square_size = int(curr_h * 0.05)
                
                # Calculate padding to fill ~80% of the view
                span_w = int(curr_w * 0.8)
                span_h = int(curr_h * 0.8)
                padding_x = (span_w - grid_cols * square_size) // (grid_cols - 1)
                padding_y = (span_h - grid_rows * square_size) // (grid_rows - 1)

                grid_w = grid_cols * square_size + (grid_cols - 1) * padding_x
                grid_h = grid_rows * square_size + (grid_rows - 1) * padding_y

                # Draw on both eyes
                for eye_idx, preview in enumerate([left_preview, right_preview]):
                    sign = -1 if eye_idx == 0 else 1
                    cx = int(center_x + sign * display_horizontal_offset / 2.0)
                    start_x = cx - grid_w // 2
                    start_y = curr_h // 2 - grid_h // 2

                    for r in range(grid_rows):
                        for c in range(grid_cols):
                            x = start_x + c * (square_size + padding_x)
                            y = start_y + r * (square_size + padding_y)
                            color = grid_colors[r * grid_cols + c]
                            cv2.rectangle(preview, (x, y), (x + square_size, y + square_size), color, -1)

                # Draw white circle for aspect ratio calibration (80% of height)
                for eye_idx, preview in enumerate([left_preview, right_preview]):
                    sign = -1 if eye_idx == 0 else 1
                    cx = int(center_x + sign * display_horizontal_offset / 2.0)
                    cy = curr_h // 2
                    radius = int(curr_h * 0.4)
                    cv2.circle(preview, (cx, cy), radius, (255, 255, 255), 4)
                
                # Print debug to terminal (optional, but helps user see it's working)
                # print(f"Display Offset: {display_horizontal_offset}", end='\r')

            preview = np.hstack([left_preview, right_preview])

            h_min, h_max = offset_valid_range(original_w, crop_w)
            v_min, v_max = offset_valid_range(original_h, crop_h)
            mode_name = color_calibration_modes[current_color_mode_idx]
            info = (
                f"original:{original_w}x{original_h} crop:{crop_w}x{crop_h} "
                f"resize:{resize_percent}% "
                f"shift(h,v):({horizontal_shift},{vertical_shift}) "
                f"display_offset:{display_horizontal_offset} "
                f"color mode:{mode_name}"
            )
            controls = "+/-:size o/p:stretch arrows:cam_shift r:reset c:color g:grid []:display_offset f:fs q:quit v:PSM"
            
            if split_mode:
                cv2.putText(left_preview, info, (10, 24), cv2.FONT_HERSHEY_SIMPLEX, 0.55, (0, 255, 0), 2, cv2.LINE_AA)
                cv2.putText(left_preview, controls, (10, 48), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1, cv2.LINE_AA)
                cv2.imshow(left_window_name, left_preview)
                cv2.imshow(right_window_name, right_preview)
            else:
                cv2.putText(preview, info, (10, 24), cv2.FONT_HERSHEY_SIMPLEX, 0.55, (0, 255, 0), 2, cv2.LINE_AA)
                cv2.putText(preview, controls, (10, 48), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 1, cv2.LINE_AA)
                display = preview
                if preview_fullscreen:
                    try:
                        _, _, win_w, win_h = cv2.getWindowImageRect(window_name)
                        if win_w > 0 and win_h > 0:
                            display = cv2.resize(preview, (win_w, win_h), interpolation=cv2.INTER_LINEAR)
                    except cv2.error:
                        pass
                cv2.imshow(window_name, display)

            gray_left = cv2.cvtColor(left_out, cv2.COLOR_BGR2GRAY)
            gray_right = cv2.cvtColor(right_out, cv2.COLOR_BGR2GRAY)
            bgr_left = cv2.cvtColor(gray_left, cv2.COLOR_GRAY2BGR).astype(np.int16)
            bgr_right = cv2.cvtColor(gray_right, cv2.COLOR_GRAY2BGR).astype(np.int16)
            bgr_left[:, :, 1] = np.clip(bgr_left[:, :, 1] + 40, 0, 255)
            bgr_right[:, :, 1] = np.clip(bgr_right[:, :, 1] - 40, 0, 255)
            overlay = ((bgr_left + bgr_right) / 2).astype(np.uint8)
            cv2.putText(overlay, "OVERLAY", (10, 24), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 255), 2, cv2.LINE_AA)
            cv2.imshow(overlay_name, overlay)

            cv2.waitKey(1)
            key = term.get_key()

            if key == KEY_QUIT:
                break
            if key == KEY_FULLSCREEN:
                preview_fullscreen = not preview_fullscreen
                mode = cv2.WINDOW_FULLSCREEN if preview_fullscreen else cv2.WINDOW_NORMAL
                aspect = cv2.WINDOW_FREERATIO if preview_fullscreen else cv2.WINDOW_KEEPRATIO
                if split_mode:
                    cv2.setWindowProperty(left_window_name, cv2.WND_PROP_FULLSCREEN, mode)
                    cv2.setWindowProperty(left_window_name, cv2.WND_PROP_ASPECT_RATIO, aspect)
                    cv2.setWindowProperty(right_window_name, cv2.WND_PROP_FULLSCREEN, mode)
                    cv2.setWindowProperty(right_window_name, cv2.WND_PROP_ASPECT_RATIO, aspect)
                else:
                    cv2.setWindowProperty(window_name, cv2.WND_PROP_FULLSCREEN, mode)
                    cv2.setWindowProperty(window_name, cv2.WND_PROP_ASPECT_RATIO, aspect)
            elif key == KEY_LEFT:
                horizontal_shift -= 2
            elif key == KEY_RIGHT:
                horizontal_shift += 2
            elif key == KEY_UP:
                vertical_shift -= 2
            elif key == KEY_DOWN:
                vertical_shift += 2
            elif key == KEY_PLUS:
                resize_percent = clip_int(resize_percent + 1, 100, 200)
            elif key == KEY_MINUS:
                resize_percent = clip_int(resize_percent - 1, 100, 200)
            elif key == KEY_STRETCH_OUT:
                width_offset += 2
            elif key == KEY_STRETCH_IN:
                width_offset -= 2
            elif key == KEY_RESET_SHIFT:
                horizontal_shift = 0
                vertical_shift = 0
            elif key == KEY_COLOR_CALIBRATE:
                current_color_mode_idx = (current_color_mode_idx + 1) % len(color_calibration_modes)
                mode_name = color_calibration_modes[current_color_mode_idx]
                left_color_calibration, right_color_calibration = calculate_calibration(mode_name, left_out, right_out)
            elif key == KEY_LINE_TOGGLE:
                show_grid = not show_grid
            elif key == KEY_LINE_LEFT:
                display_horizontal_offset -= 2
                # print(f"display_horizontal_offset: {display_horizontal_offset}")
            elif key == KEY_LINE_RIGHT:
                display_horizontal_offset += 2
                # print(f"display_horizontal_offset: {display_horizontal_offset}")
            elif key == KEY_PSM_OSCILLATE:
                if arm:
                    if not oscillating:
                        with oscillation_lock:
                            initial_jp_val, _ = arm.setpoint_jp()
                            # Use a copy of initial_jp to maintain setpoints
                            initial_jp = np.array(initial_jp_val)
                            oscillation_start_time = time.time()
                            oscillating = True
                        print(f"Starting oscillation on {psm_name} joint 4...")
                    else:
                        with oscillation_lock:
                            oscillating = False
                        # Return to initial position
                        arm.move_jp(initial_jp)
                        print(f"Stopped oscillation on {psm_name}.")
                else:
                    print("Error: No PSM specified for oscillation. Use -p/--psm [PSM name].")

    left_cap.release()
    right_cap.release()
    cv2.destroyAllWindows()

    return {
        "left_stream": left_stream,
        "right_stream": right_stream,
        "original_width": int(original_w),
        "original_height": int(original_h),
        "crop_width": int(crop_w),
        "crop_height": int(crop_h),
        "resize_percent": int(resize_percent),
        "horizontal_shift_px": int(horizontal_shift),
        "vertical_shift_px": int(vertical_shift),
        "display_horizontal_offset_px": int(display_horizontal_offset),
        "left_color": left_color_calibration,
        "right_color": right_color_calibration,
    }

def main():
    args = parse_args()
    path = Path(args.config)
    file_exists = path.exists()

    if not file_exists and (not args.left or not args.right):
        print("Error: config file does not exist. Please provide both -l/--left and -r/--right to create it.")
        return 1

    config = load_or_create(path)

    ensure_config_fields(config)
    apply_stream_overrides(config, args)

    try:
        split_mode = args.split or "glimages" in config.get("sinks", [])
        runtime_values = interactive_tune(config, split_mode=split_mode, psm_name=args.psm)
    except RuntimeError as exc:
        print(f"Error: {exc}")
        return 1

    update_config_from_runtime(
        config,
        runtime_values["left_stream"],
        runtime_values["right_stream"],
        runtime_values["original_width"],
        runtime_values["original_height"],
        runtime_values["crop_width"],
        runtime_values["crop_height"],
        runtime_values["horizontal_shift_px"],
        runtime_values["vertical_shift_px"],
        runtime_values["display_horizontal_offset_px"],
        runtime_values["left_color"],
        runtime_values["right_color"]
    )

    while True:
        decision = input(f"Save updated configuration to {path}? [y/N]: ").strip().lower()
        if decision in ("y", "yes"):
            save_requested = True
            break
        if decision in ("", "n", "no"):
            save_requested = False
            break
        print("Please answer with y/yes or n/no.")

    if not save_requested:
        print("Changes discarded.")
        return 0

    rendered = json.dumps(config, indent=2)

    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as stream:
        stream.write(rendered + "\n")

    print(f"Wrote {path}")
    print("Saved fields: left_stream, right_stream, original_*, crop_*, *_shift_px")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
