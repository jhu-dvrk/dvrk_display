{
  "type": "dd::display_config@1.0.0",
  "name": "stereo_complex",
  "dvrk_console_namespace": "console",
  "original_width": 640,
  "original_height": 480,
  "crop_width": 640,
  "crop_height": 480,
  "sinks": ["glimage", "glimages"],
  "overlay_alpha": 0.5,
  "extra_streams": {
    "monos": [
      "videotestsrc pattern=snow ! video/x-raw,width=320,height=240,framerate=10/1"
    ],
    "scale": 0.3
  },
  "left": "videotestsrc pattern=white ! video/x-raw,width=640,height=480,framerate=30/1",
  "right": "videotestsrc pattern=black ! video/x-raw,width=640,height=480,framerate=30/1"
}
